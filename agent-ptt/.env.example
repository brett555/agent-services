# Speaches server (self-hosted STT/TTS, OpenAI-compatible)
SPEACHES_BASE_URL=http://10.0.0.1:8000
SPEACHES_STT_MODEL=Systran/faster-distil-whisper-small.en
SPEACHES_TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX
SPEACHES_TTS_VOICE=af_heart

# Zello Work Channel API
# For Zello Work: username + password only, no auth_token needed
ZELLO_SERVER_URL=wss://zello.io/ws
ZELLO_CHANNEL=your_channel_name
ZELLO_USERNAME=your_bot_username
ZELLO_PASSWORD=your_bot_password
# ZELLO_AUTH_TOKEN=  # Only needed for consumer Zello (not Zello Work)

# OpenClaw Personal Assistant webhook
PA_WEBHOOK_URL=http://10.0.0.2:8000/incoming

# REST API for PA to call agent-ptt
API_PORT=8080
API_KEY=change_me_to_a_secure_random_string
